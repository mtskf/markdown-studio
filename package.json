{
  "name": "its-markdown-studio",
  "displayName": "Markdown Studio",
  "description": "Notion-like WYSIWYG markdown editor with rich diffs, tables, images, math, and more.",
  "version": "2.3.11",
  "publisher": "tanishq-chaudhary",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chaudhary1337/markdown-studio"
  },
  "bugs": {
    "url": "https://github.com/chaudhary1337/markdown-studio/issues"
  },
  "homepage": "https://github.com/chaudhary1337/markdown-studio",
  "icon": "assets/logo7.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters",
    "Visualization"
  ],
  "keywords": [
    "markdown",
    "wysiwyg",
    "editor",
    "notion",
    "rich text",
    "rich diff",
    "diff",
    "md",
    "rich editor",
    "table",
    "math",
    "latex",
    "katex",
    "preview",
    "documentation",
    "notes",
    "note-taking",
    "gfm",
    "writing",
    "wiki",
    "notion-like",
    "rich text editor",
    "live preview",
    "knowledge base",
    "readme",
    "wysiwyg editor",
    "rich markdown",
    "github flavored markdown"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "betterMarkdown.editor",
        "displayName": "Markdown Studio",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "betterMarkdown.toggleEditor",
        "title": "Toggle Rich/Source Editor",
        "category": "Markdown Studio",
        "icon": "$(notebook-render-output)"
      },
      {
        "command": "betterMarkdown.find",
        "title": "Find in Document",
        "category": "Markdown Studio"
      },
      {
        "command": "betterMarkdown.openDiff",
        "title": "Open Rich Diff",
        "category": "Markdown Studio",
        "icon": "$(diff)"
      },
      {
        "command": "betterMarkdown.factoryReset",
        "title": "Factory Reset Settings",
        "category": "Markdown Studio"
      },
      {
        "command": "betterMarkdown.claudeCodeInsertAtMentioned",
        "title": "Insert @-Mention of Current File into Claude Code",
        "category": "Markdown Studio"
      }
    ],
    "keybindings": [
      {
        "command": "betterMarkdown.toggleEditor",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "resourceExtname == .md"
      },
      {
        "command": "betterMarkdown.find",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "activeCustomEditorId == betterMarkdown.editor"
      },
      {
        "command": "betterMarkdown.claudeCodeInsertAtMentioned",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k",
        "when": "activeCustomEditorId == betterMarkdown.editor"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "betterMarkdown.openDiff",
          "when": "resourceExtname == .md || isInDiffEditor"
        },
        {
          "command": "betterMarkdown.claudeCodeInsertAtMentioned",
          "when": "activeCustomEditorId == betterMarkdown.editor"
        }
      ],
      "editor/title": [
        {
          "command": "betterMarkdown.toggleEditor",
          "group": "navigation",
          "when": "resourceExtname == .md"
        },
        {
          "command": "betterMarkdown.openDiff",
          "group": "navigation",
          "when": "isInDiffEditor && resourceExtname == .md"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "betterMarkdown.openDiff",
          "group": "1_modification",
          "when": "scmProvider == git && resourceExtname == .md"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Studio",
      "properties": {
        "markdownStudio.autoSave": {
          "type": "boolean",
          "default": true,
          "order": 1,
          "markdownDescription": "Save the file silently on first open to persist the normalization round-trip (md → html → md). Subsequent edits follow VS Code's own `#files.autoSave#` / manual-save behavior."
        },
        "markdownStudio.bullet": {
          "type": "string",
          "enum": ["-", "*", "+"],
          "enumDescriptions": ["dash", "star", "plus"],
          "default": "-",
          "order": 10,
          "markdownDescription": "Bullet character for unordered lists when serializing back to markdown."
        },
        "markdownStudio.emphasis": {
          "type": "string",
          "enum": ["_", "*"],
          "enumDescriptions": ["_italic_", "*italic*"],
          "default": "_",
          "order": 11,
          "markdownDescription": "Emphasis (italic) marker."
        },
        "markdownStudio.strong": {
          "type": "string",
          "enum": ["**", "__"],
          "enumDescriptions": ["**bold**", "__bold__"],
          "default": "**",
          "order": 12,
          "markdownDescription": "Strong (bold) marker."
        },
        "markdownStudio.rule": {
          "type": "string",
          "enum": ["-", "*", "_"],
          "enumDescriptions": ["---", "***", "___"],
          "default": "-",
          "order": 13,
          "markdownDescription": "Horizontal-rule character. Rendered as three of whichever you pick."
        },
        "markdownStudio.listItemIndent": {
          "type": "string",
          "enum": ["one", "tab", "mixed"],
          "enumDescriptions": ["1 space", "tab", "mixed"],
          "default": "one",
          "order": 14,
          "markdownDescription": "Continuation indent for list items."
        },
        "markdownStudio.bubbleMenuShortcut": {
          "type": "string",
          "default": "Mod+/",
          "order": 20,
          "markdownDescription": "Keybinding that opens the selection bubble menu. If the cursor is inside a word with no active selection, the shortcut expands the selection to the surrounding word first. Format: modifier+key chain separated by `+` (e.g. `Mod+/`, `Ctrl+Shift+B`). `Mod` resolves to `Meta` on macOS, `Ctrl` elsewhere. Empty string disables the shortcut."
        },
        "markdownStudio.defaultCodeBlockLang": {
          "type": "string",
          "default": "",
          "order": 30,
          "markdownDescription": "Language label applied to unlabelled code blocks. Empty leaves them bare (\\`\\`\\`); `text` / `plaintext` adds a default label."
        },
        "markdownStudio.diffMode": {
          "type": "string",
          "enum": ["source", "rendered"],
          "enumDescriptions": ["Source (line diff)", "Rendered (HTML diff)"],
          "default": "rendered",
          "order": 40,
          "markdownDescription": "Default view for the rich diff panel."
        },
        "markdownStudio.diffLayout": {
          "type": "string",
          "enum": ["unified", "side-by-side"],
          "enumDescriptions": ["Unified", "Side-by-side"],
          "default": "side-by-side",
          "order": 41,
          "markdownDescription": "Layout for the source (line-level) diff toggle."
        },
        "markdownStudio.compactLists": {
          "type": "boolean",
          "default": true,
          "order": 50,
          "markdownDescription": "Remove blank lines between consecutive list items (tight lists)."
        },
        "markdownStudio.unescapeSpecialChars": {
          "type": "boolean",
          "default": true,
          "order": 51,
          "markdownDescription": "Strip redundant `\\~`, `\\*`, `\\_`, `\\[` escapes that remark-stringify adds defensively."
        },
        "markdownStudio.renumberOrderedLists": {
          "type": "boolean",
          "default": true,
          "order": 52,
          "markdownDescription": "Renumber ordered list items to `1.`, `2.`, `3.`, …"
        },
        "markdownStudio.shellscriptToBash": {
          "type": "boolean",
          "default": true,
          "order": 53,
          "markdownDescription": "Rewrite code fences labelled `shellscript` → `bash`."
        },
        "markdownStudio.fixTableHeaders": {
          "type": "boolean",
          "default": true,
          "order": 54,
          "markdownDescription": "Rebuild table headers when rehype-remark emits an empty header row."
        },
        "markdownStudio.dedupImageAltText": {
          "type": "boolean",
          "default": true,
          "order": 55,
          "markdownDescription": "Collapse `![alt](x)\\nalt` → `![alt](x)` (image followed by its alt)."
        }
      }
    }
  },
  "scripts": {
    "test": "npx tsx test/test-conversions.ts && npx tsx test/test-roundtrip.ts",
    "test:conversions": "npx tsx test/test-conversions.ts",
    "test:roundtrip": "npx tsx test/test-roundtrip.ts",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "deploy": "bash scripts/deploy.sh",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@tiptap/extension-bubble-menu": "^3.22.1",
    "@tiptap/extension-code": "^3.22.1",
    "@tiptap/extension-code-block-lowlight": "^3.22.1",
    "@tiptap/extension-image": "^3.22.1",
    "@tiptap/extension-link": "^3.22.1",
    "@tiptap/extension-table": "^3.22.1",
    "@tiptap/extension-table-cell": "^3.22.1",
    "@tiptap/extension-table-header": "^3.22.1",
    "@tiptap/extension-table-row": "^3.22.1",
    "@tiptap/extension-task-item": "^3.22.1",
    "@tiptap/extension-task-list": "^3.22.1",
    "@tiptap/pm": "^3.22.1",
    "@tiptap/react": "^3.22.1",
    "@tiptap/starter-kit": "^3.22.1",
    "@tiptap/suggestion": "^3.22.1",
    "diff": "^8.0.4",
    "diff2html": "^3.4.56",
    "katex": "^0.16.45",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.7.0",
    "mermaid": "^11.14.0",
    "node-htmldiff": "^0.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5"
  }
}
